{
  "apps": [
    {
      "name": "lapetitevitrine-api",
      "script": "server.js",
      "instances": 1,
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "development",
        "PORT": 3001
      },
      "env_production": {
        "NODE_ENV": "production",
        "PORT": 3001
      },
      "log_file": "logs/app.log",
      "error_file": "logs/error.log",
      "out_file": "logs/out.log",
      "log_date_format": "YYYY-MM-DD HH:mm Z",
      "merge_logs": true,
      "restart_delay": 1000,
      "max_restarts": 10,
      "watch": false,
      "ignore_watch": ["node_modules", "logs", "dist"],
      "watch_options": {
        "followSymlinks": false
      }
    }
  ]
}